# Server-side only. Never expose these values in browser JavaScript or commit them.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6

# The three-perspective dialogue is latency-gated. Measured on the real ~5300-char
# strict-json_schema payload: gpt-5.6 decodes at ~25 output tok/s and exceeds the 15s
# request timeout, so EVERY dialogue request 502s. gpt-5.3-codex-spark serves the same
# payload in ~2.4s. Setting LLM_MODEL here overrides the in-code default -- if you change
# it, check the [llm] line the server prints at boot.
LLM_MODEL=gpt-5.3-codex-spark
OPENAI_REALTIME_MODEL=gpt-realtime-2.1

# Optional Phase 3 asset/world generation services.
WORLDLABS_API_KEY=
WORLDLABS_MODEL=marble-1.1
TRIPO_API_KEY=
TRIPO_MODEL=P1-20260311
TRIPO_RIG_MODEL=v2.5-20250123

# Required for every World Labs or Tripo generation/task route. Send it as
# Authorization: Bearer <token>. Use a long random server-side value.
INTEGRATION_ADMIN_TOKEN=

# Required only when submitting bundled character views to Tripo. Must be the
# deployed public HTTPS root that serves assets/generated/turnarounds/views/.
PUBLIC_APP_URL=

# Art Institute of Chicago Open Access and IIIF do not require an API key.
